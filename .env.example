# ---------------------------------------------------------------------------
# Pulse local configuration. Copy to .env and adjust.
# ---------------------------------------------------------------------------

# Database (all services) — points at the docker-compose Postgres.
# If 5432 is already taken (e.g. a native Postgres install), set POSTGRES_PORT
# to a free port and update the port in DATABASE_URL to match.
POSTGRES_PORT=5432
DATABASE_URL="postgresql://pulse:pulse@localhost:5432/pulse?schema=public"

# Auth (api)
JWT_SECRET="dev-change-me-access-secret"
JWT_REFRESH_SECRET="dev-change-me-refresh-secret"
JWT_ACCESS_TTL="15m"
JWT_REFRESH_TTL="7d"

# AWS / SQS (scheduler, worker) — LocalStack locally
AWS_REGION="ap-southeast-2"
AWS_ACCESS_KEY_ID="test"
AWS_SECRET_ACCESS_KEY="test"
AWS_ENDPOINT_URL="http://localhost:4566"
SQS_QUEUE_URL="http://localhost:4566/000000000000/check-jobs"

# Scheduler — how often the claim-and-enqueue loop runs (ms)
SCHEDULER_INTERVAL_MS="60000"

# Retention — delete check_result rows older than this many days (daily job)
RETENTION_DAYS="30"

# Alerts (worker)
SES_FROM_ADDRESS="alerts@pulse.local"
SLACK_WEBHOOK_URL=""

# Checker (worker)
CHECK_DEFAULT_TIMEOUT_MS="10000"

# Logging (all)
LOG_LEVEL="debug"
NODE_ENV="development"

# Ports
API_PORT="3000"
