// Pulse data model — see README.md §3 for the ER diagram and indexing notes.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum MonitorStatus {
  UP
  DOWN
  PAUSED
  PENDING
}

enum HttpMethod {
  GET
  POST
  HEAD
}

enum AlertChannelType {
  EMAIL
  SLACK_WEBHOOK
}

enum AlertKind {
  DOWN
  RECOVERED
}

enum DeliveryStatus {
  SENT
  FAILED
}

model User {
  id           String         @id @default(uuid()) @db.Uuid
  email        String         @unique
  passwordHash String         @map("password_hash")
  createdAt    DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  monitors     Monitor[]
  alertChannels AlertChannel[]

  @@map("user")
}

model Monitor {
  id                  String        @id @default(uuid()) @db.Uuid
  userId              String        @map("user_id") @db.Uuid
  name                String
  url                 String
  method              HttpMethod    @default(GET)
  intervalSeconds     Int           @map("interval_seconds")
  expectedStatus      Int           @default(200) @map("expected_status")
  timeoutMs           Int           @default(10000) @map("timeout_ms")
  failureThreshold    Int           @default(2) @map("failure_threshold")
  status              MonitorStatus @default(PENDING)
  consecutiveFailures Int           @default(0) @map("consecutive_failures")
  nextCheckAt         DateTime      @default(now()) @map("next_check_at") @db.Timestamptz(6)
  createdAt           DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  checkResults CheckResult[]
  incidents    Incident[]

  // The scheduler's only query. A partial index excluding PAUSED is added via
  // raw SQL in the migration (Prisma schema cannot express WHERE on indexes).
  @@index([nextCheckAt])
  @@index([userId])
  @@map("monitor")
}

model CheckResult {
  id             BigInt   @id @default(autoincrement())
  monitorId      String   @map("monitor_id") @db.Uuid
  success        Boolean
  statusCode     Int?     @map("status_code")
  responseTimeMs Int      @map("response_time_ms")
  error          String?
  checkedAt      DateTime @default(now()) @map("checked_at") @db.Timestamptz(6)

  monitor Monitor @relation(fields: [monitorId], references: [id], onDelete: Cascade)

  // Serves the dashboard chart and uptime aggregation.
  @@index([monitorId, checkedAt(sort: Desc)])
  @@map("check_result")
}

model Incident {
  id         String    @id @default(uuid()) @db.Uuid
  monitorId  String    @map("monitor_id") @db.Uuid
  startedAt  DateTime  @default(now()) @map("started_at") @db.Timestamptz(6)
  resolvedAt DateTime? @map("resolved_at") @db.Timestamptz(6)
  cause      String?

  monitor     Monitor      @relation(fields: [monitorId], references: [id], onDelete: Cascade)
  alertEvents AlertEvent[]

  @@index([monitorId, startedAt(sort: Desc)])
  @@map("incident")
}

model AlertChannel {
  id          String           @id @default(uuid()) @db.Uuid
  userId      String           @map("user_id") @db.Uuid
  type        AlertChannelType
  destination String
  enabled     Boolean          @default(true)

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  alertEvents AlertEvent[]

  @@index([userId])
  @@map("alert_channel")
}

model AlertEvent {
  id             String         @id @default(uuid()) @db.Uuid
  incidentId     String         @map("incident_id") @db.Uuid
  channelId      String         @map("channel_id") @db.Uuid
  kind           AlertKind
  deliveryStatus DeliveryStatus @map("delivery_status")
  sentAt         DateTime       @default(now()) @map("sent_at") @db.Timestamptz(6)

  incident Incident     @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  channel  AlertChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@index([incidentId])
  @@map("alert_event")
}
